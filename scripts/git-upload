#!/usr/bin/env bash
# Commit and push all repos and submodules, overwriting remote history (forced).
# Order: deepest submodule first, then work back to root.
set -e

root="$(git rev-parse --show-toplevel)"
msg="${1:-Update}"
cd "$root"

commit_and_force_push_repo() {
  local dir="$1"
  (cd "$dir" && {
    # If detached, create/switch to a common branch so we can push HEAD cleanly.
    if [ "$(git rev-parse --abbrev-ref HEAD)" = "HEAD" ]; then
      git checkout -B main 2>/dev/null || git checkout -B master 2>/dev/null || true
    fi

    git add -A
    git commit -m "$msg" || true

    # If no upstream, set one. Always force push to overwrite remote.
    if git rev-parse --abbrev-ref --symbolic-full-name '@{u}' >/dev/null 2>&1; then
      git push --force || true
    else
      git push -u origin HEAD --force || true
    fi
  })
}

if [ -f .gitmodules ]; then
  paths="$(git submodule foreach --recursive --quiet 'echo "$(git rev-parse --show-toplevel)"')"
  for dir in $(echo "$paths" | awk '{a[NR]=$0} END{for(i=NR;i>=1;i--) print a[i]}'); do
    rel="${dir#$root/}"
    [ -z "$rel" ] && rel="."
    echo "Entering '$rel'"
    commit_and_force_push_repo "$dir"
  done
fi

echo "Entering '.'"
git add -A
git commit -m "$msg" || true

if git rev-parse --abbrev-ref --symbolic-full-name '@{u}' >/dev/null 2>&1; then
  git push --force --recurse-submodules=on-demand
else
  git push -u origin HEAD --force --recurse-submodules=on-demand
fi

