#!/usr/bin/env bash
# Push all submodules (recursive, deepest first), then this repo
# Recursive: every nested submodule. Order: end of tree first, then work back to root.
set -e
root="$(git rev-parse --show-toplevel)"
cd "$root"
if [ -f .gitmodules ]; then
  paths=$(git submodule foreach --recursive --quiet 'echo "$(git rev-parse --show-toplevel)"')
  for dir in $(echo "$paths" | awk '{a[NR]=$0} END{for(i=NR;i>=1;i--) print a[i]}'); do
    rel="${dir#$root/}"
    [ -z "$rel" ] && rel="."
    echo "Entering '$rel'"
    (cd "$dir" && {
      if [ "$(git rev-parse --abbrev-ref HEAD)" = "HEAD" ]; then
        git checkout -B main 2>/dev/null || git checkout -B master 2>/dev/null || true
      fi
      git push || true
    })
  done
fi
echo "Entering '.'"
git push --recurse-submodules=on-demand
